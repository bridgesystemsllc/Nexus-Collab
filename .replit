run = "npm run start"
entrypoint = "apps/api/src/index.ts"

[nix]
channel = "stable-24_05"

[env]
NODE_ENV = "development"
PORT = "3000"
DATABASE_URL = "postgresql://runner:password@localhost:5432/nexus"
REDIS_URL = "redis://localhost:6379"

[packager]
language = "nodejs"

[packager.features]
packageSearch = true
guessImports = true

[deployment]
run = ["sh", "-c", "npm run build && npm run start:prod"]
deploymentTarget = "cloudrun"
ignorePorts = false

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3000/tcp 5000/tcp 2>/dev/null; DATABASE_URL=\"postgresql://postgres:${PGPASSWORD}@helium:5432/nexus\" /home/runner/workspace/apps/api/node_modules/.bin/tsx apps/api/src/index.ts & sleep 3 && cd /home/runner/workspace/apps/web && pnpm run dev"
waitForPort = 5000

[agent]
expertMode = true
