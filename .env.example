# Database
DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus"
REDIS_URL="redis://localhost:6379"

# Auth (Clerk)
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

# AI (Anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# Microsoft Graph
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID=""
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/v1/integrations/microsoft/callback"

# File Storage (Cloudflare R2 / S3-compatible)
S3_ENDPOINT="https://xxxx.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="nexus-files"
S3_PUBLIC_URL="https://files.nexus.app"

# Search
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="your-meili-master-key"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/integrations/google/callback"

# Token Encryption (32-byte hex key for AES-256-GCM)
TOKEN_ENCRYPTION_KEY=""

# ERP
ERP_API_URL="https://api.karevesync.com/v1"
ERP_API_KEY=""

# Email Agent (Outlook → Nexus Collab AI)
AGENT_MAILBOX="agent@nexuscollab.com"
AGENT_WEBHOOK_SECRET=""
AUTHORIZED_SENDERS="ahmad@kareve.com"
# GRAPH_* (falling back to MICROSOFT_*) app credentials are also used by the
# SharePoint folder viewer (GET /api/v1/sharepoint/list). The app registration
# needs the Files.Read.All APPLICATION permission for folder listing to work.
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""

# Sessions (express-session, PostgreSQL-backed)
# REQUIRED — the API refuses to start without it. Use a long random string.
SESSION_SECRET=""

# Formulations password gate (optional)
# When set, the R&D Formulations module (UI + formulation-detail/sharepoint
# APIs) requires this password once per session. Store ONLY the sha256 hex
# digest of the password — never the plaintext. Generate with:
#   node -e "console.log(require('crypto').createHash('sha256').update('yourpassword').digest('hex'))"
# Leave unset to disable the gate.
FORMULATIONS_PASSWORD_HASH=""

# App
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
