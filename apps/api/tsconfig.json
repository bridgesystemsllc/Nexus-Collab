{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@nexus/shared": ["../../packages/shared/src"],
      "@nexus/prisma": ["../../packages/prisma"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
