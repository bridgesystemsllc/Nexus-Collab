{
  "name": "nexus-collab",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "pnpm --filter @nexus/api dev",
    "dev:web": "pnpm --filter @nexus/web dev",
    "dev:worker": "pnpm --filter @nexus/api dev:worker",
    "build": "pnpm --filter @nexus/web build",
    "build:api": "pnpm --filter @nexus/api build",
    "start": "node scripts/dev.mjs",
    "start:prod": "node apps/api/dist/index.js",
    "setup": "node scripts/setup.mjs",
    "db:generate": "pnpm --filter @nexus/prisma generate",
    "db:migrate": "pnpm --filter @nexus/prisma migrate",
    "db:push": "cd packages/prisma && npx prisma db push",
    "db:seed": "cd packages/prisma && npx tsx prisma/seed.ts",
    "db:studio": "cd packages/prisma && npx prisma studio",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
