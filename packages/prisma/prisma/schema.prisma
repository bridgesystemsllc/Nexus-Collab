generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization ───────────────────────────────────────────
model Organization {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  logoUrl            String?
  color              String?
  industry           String?
  usageContext       String?
  referralSource     String?
  phoneNumber        String?
  featureInterests   String[]
  onboardingComplete Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  departments        Department[]
  brands             Brand[]
  members            Member[]
  projects           Project[]
  documents          Document[]
  integrations       Integration[]
  products           Product[]
  transitionSkus     TransitionSku[]
  invites            OrganizationInvite[]
}

// ─── Organization Invite ────────────────────────────────────
model OrganizationInvite {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  invitedEmail String
  role         String       @default("member")
  invitedBy    String
  inviter      Member       @relation(fields: [invitedBy], references: [id])
  token        String       @unique
  status       String       @default("pending") // pending, accepted, expired
  expiresAt    DateTime
  createdAt    DateTime     @default(now())

  @@index([orgId])
  @@index([token])
}

// ─── Member ─────────────────────────────────────────────────
model Member {
  id           String     @id @default(cuid())
  clerkUserId  String     @unique
  email        String     @unique
  name         String
  avatar       String?
  role         String     @default("MEMBER") // ADMIN, OPS_MANAGER, DEPT_LEAD, PROJECT_LEAD, MEMBER
  status       String     @default("AVAILABLE") // AVAILABLE, FOCUSED, IN_MEETING, OOO
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  departmentId String?
  department   Department?  @relation(fields: [departmentId], references: [id])
  activities   Activity[]
  tasksOwned   Task[]       @relation("TaskOwner")
  notes        Note[]
  invitesSent  OrganizationInvite[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([orgId])
  @@index([clerkUserId])
}

// ─── Department ─────────────────────────────────────────────
model Department {
  id          String             @id @default(cuid())
  name        String
  description String?
  icon        String             @default("circle")
  color       String             @default("#0A84FF")
  type        String             @default("CUSTOM") // BUILTIN_RD, BUILTIN_OPS, CUSTOM
  orgId       String
  org         Organization       @relation(fields: [orgId], references: [id])
  members     Member[]
  modules     DepartmentModule[]
  tasks       Task[]
  archived    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([orgId])
}

// ─── Department Module ──────────────────────────────────────
model DepartmentModule {
  id           String       @id @default(cuid())
  name         String
  type         String       // BRIEFS, CM_PRODUCTIVITY, TECH_TRANSFERS, FORMULATIONS, SKU_PIPELINE, INVENTORY_HEALTH, PRODUCTION_TRACKING, CUSTOM_TABLE, CUSTOM_KANBAN, CUSTOM_LIST
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id])
  config       Json         @default("{}")
  items        ModuleItem[]
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())

  @@index([departmentId])
}

// ─── Module Item ────────────────────────────────────────────
model ModuleItem {
  id        String           @id @default(cuid())
  moduleId  String
  module    DepartmentModule @relation(fields: [moduleId], references: [id])
  data      Json
  status    String?
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([moduleId])
}

// ─── Brand ──────────────────────────────────────────────────
model Brand {
  id    String       @id @default(cuid())
  name  String
  color String
  icon  String
  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

// ─── Product ────────────────────────────────────────────────
model Product {
  id           String   @id @default(cuid())
  name         String
  brand        String
  category     String
  sku          String?  @unique
  upc          String?
  description  String?
  retailPrice  String?
  cogs         String?
  status       String   @default("ACTIVE") // ACTIVE, IN_DEVELOPMENT, DISCONTINUED
  imageUrl     String?
  weight       String?
  dimensions   String?
  ingredients  String?
  manufacturer String?
  variants     Json?
  kareveId     String?  @unique
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId])
  @@index([status])
}

// ─── Project ────────────────────────────────────────────────
model Project {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      String       @default("ACTIVE") // DRAFT, ACTIVE, BLOCKED, REVIEW, COMPLETE, ARCHIVED
  priority    String       @default("P2") // P0, P1, P2, P3
  health      Int          @default(100)
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])
  leadId      String?
  tasks       Task[]
  coworkSpace CoworkSpace?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId])
}

// ─── Cowork Space ───────────────────────────────────────────
model CoworkSpace {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        String     @default("PROJECT") // PROJECT, EMERGENCY, INITIATIVE, DEPARTMENT
  status      String     @default("ACTIVE") // ACTIVE, ARCHIVED
  projectId   String?    @unique
  project     Project?   @relation(fields: [projectId], references: [id])
  deptNames   String[]
  memberIds   String[]
  activities  Activity[]
  tasks       Task[]     @relation("CoworkTasks")
  documents   Document[] @relation("CoworkDocs")
  emails      EmailLink[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Task ───────────────────────────────────────────────────
model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  status       String       @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, IN_REVIEW, BLOCKED, COMPLETE
  priority     String       @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW
  effort       String?      // XS, S, M, L, XL
  dueDate      DateTime?
  completedAt  DateTime?
  brandNames   String[]
  projectId    String?
  project      Project?     @relation(fields: [projectId], references: [id])
  departmentId String?
  department   Department?  @relation(fields: [departmentId], references: [id])
  ownerId      String?
  owner        Member?      @relation("TaskOwner", fields: [ownerId], references: [id])
  coworkSpaces CoworkSpace[] @relation("CoworkTasks")
  documents    Document[]   @relation("TaskDocs")
  emails       EmailLink[]
  notes        Note[]
  parentId     String?
  parent       Task?        @relation("SubTasks", fields: [parentId], references: [id])
  subtasks     Task[]       @relation("SubTasks")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([projectId])
  @@index([departmentId])
  @@index([ownerId])
  @@index([status])
}

// ─── Activity ───────────────────────────────────────────────
model Activity {
  id            String      @id @default(cuid())
  type          String      // UPDATE, SUBMISSION, NOTE, STATUS_CHANGE, FILE_UPLOAD, EMAIL_LINKED, TASK_CREATED, TASK_COMPLETED, AI_ACTION
  content       String
  coworkSpaceId String?
  coworkSpace   CoworkSpace? @relation(fields: [coworkSpaceId], references: [id])
  authorId      String
  author        Member      @relation(fields: [authorId], references: [id])
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([coworkSpaceId])
  @@index([authorId])
}

// ─── Document ───────────────────────────────────────────────
model Document {
  id           String       @id @default(cuid())
  name         String
  mimeType     String
  size         Int
  storageKey   String
  storageUrl   String?
  type         String       @default("OTHER") // BRIEF, COA, SPEC_SHEET, QUOTE, PRICING, CONTRACT, REPORT, ARTWORK, INVOICE, OTHER
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  uploadedById String
  coworkSpaces CoworkSpace[] @relation("CoworkDocs")
  tasks        Task[]       @relation("TaskDocs")
  version      Int          @default(1)
  parentDocId  String?
  createdAt    DateTime     @default(now())

  @@index([orgId])
  @@index([type])
}

// ─── Email Link ─────────────────────────────────────────────
model EmailLink {
  id             String       @id @default(cuid())
  messageId      String
  subject        String
  fromAddr       String
  toAddrs        String[]
  date           DateTime
  snippet        String?
  taskId         String?
  task           Task?        @relation(fields: [taskId], references: [id])
  coworkSpaceId  String?
  coworkSpace    CoworkSpace? @relation(fields: [coworkSpaceId], references: [id])
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([taskId])
  @@index([coworkSpaceId])
}

// ─── Note ───────────────────────────────────────────────────
model Note {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    Member   @relation(fields: [authorId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

// ─── Integration ────────────────────────────────────────────
model Integration {
  id         String    @id @default(cuid())
  type       String    // ERP_KAREVE_SYNC, MICROSOFT_OUTLOOK, MICROSOFT_TEAMS, MICROSOFT_ONEDRIVE, AMAZON_VENDOR_CENTRAL, SHOPIFY, GS1_SYNC, SLACK, ZAPIER
  name       String
  status     String    @default("DISCONNECTED") // CONNECTED, DISCONNECTED, ERROR, SYNCING
  config     Json      @default("{}")
  lastSyncAt DateTime?
  syncCount  Int       @default(0)
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id])
  syncLogs   SyncLog[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([orgId])
}

// ─── Sync Log ───────────────────────────────────────────────
model SyncLog {
  id               String      @id @default(cuid())
  integrationId    String
  integration      Integration @relation(fields: [integrationId], references: [id])
  status           String
  recordsProcessed Int         @default(0)
  errors           Json?
  startedAt        DateTime    @default(now())
  completedAt      DateTime?

  @@index([integrationId])
}

// ─── Pulse ──────────────────────────────────────────────────
model Pulse {
  id        String   @id @default(cuid())
  type      String   // ALERT, SIGNAL, HEARTBEAT, BROADCAST
  message   String
  deptName  String?
  targetId  String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([targetId])
  @@index([read])
}

// ─── Email Agent Log ────────────────────────────────────────
model EmailAgentLog {
  id               String   @id @default(cuid())
  messageId        String   @unique
  senderEmail      String
  subject          String
  status           String   @default("processing") // processing, complete, partial, parse_error, awaiting_clarification
  parsedPlan       Json?
  executionResults Json?
  error            String?
  receivedAt       DateTime?
  createdAt        DateTime @default(now())

  @@index([senderEmail])
  @@index([status])
}

// ─── Escalation Rule ────────────────────────────────────────
model EscalationRule {
  id           String   @id @default(cuid())
  trigger      String
  action       String
  targetRole   String?
  delayMinutes Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ─── Brand Transition SKU ───────────────────────────────────
model TransitionSku {
  id                    String    @id @default(cuid())
  materialCode          String    @unique
  description           String
  brand                 String    @default("CarolsDaughter")
  track                 String    // loreal_coman, full_buy, disco_decision
  currentCm             String?
  lorealEntity          String?
  manufacturingProcess  String?
  transitionDeadline    DateTime? @default(dbgenerated("'2025-04-29'::timestamp"))
  newCm                 String?
  cmStatus              String    @default("Not Started")
  cmOutreachDate        DateTime?
  cmAgreementDate       DateTime?
  firstProductionDate   DateTime?
  transitionOwner       String?
  formulaTransferred    Boolean   @default(false)
  formulaTransferDate   DateTime?
  formulaOwner          String?
  rawMaterialsConfirmed Boolean   @default(false)
  rmNotes               String?
  discoDecision         String    @default("Pending") // Pending, Discontinue, Find RM and Produce
  discoDecisionDate     DateTime?
  discoDecisionOwner    String?
  rmDisengaged          String?
  lastLorealBatches     Int       @default(0)
  lastBatchEta          DateTime?
  currentInventoryUnits Int       @default(0)
  weeksOfSupply         Float?
  avgWeeklyVelocity     Float?
  overallStatus         String    @default("Needs Action") // Active, Needs Action, At Risk, Decision Required, Discontinued, Transition Complete
  isFlagged             Boolean   @default(false)
  priority              String    @default("Medium") // High, Medium, Low
  isCowork              Boolean   @default(false)
  coworkType            String?
  coworkNote            String?
  coworkAssignedTo      String?
  coworkResolved        Boolean   @default(false)
  notes                 String?
  orgId                 String
  org                   Organization @relation(fields: [orgId], references: [id])
  transitionNotes       TransitionNote[]
  milestones            TransitionMilestone[]
  cmCandidates          CmCandidate[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([orgId])
  @@index([track])
  @@index([overallStatus])
}

// ─── Transition Note ────────────────────────────────────────
model TransitionNote {
  id        String   @id @default(cuid())
  skuId     String
  sku       TransitionSku @relation(fields: [skuId], references: [id], onDelete: Cascade)
  noteType  String   @default("Update") // Update, CM Outreach, Legal / Agreement, Formula Transfer, RM Update, Decision, CoWork, System
  noteText  String
  createdBy String?
  createdAt DateTime @default(now())

  @@index([skuId])
}

// ─── Transition Milestone ───────────────────────────────────
model TransitionMilestone {
  id            String    @id @default(cuid())
  skuId         String
  sku           TransitionSku @relation(fields: [skuId], references: [id], onDelete: Cascade)
  milestoneName String
  dueDate       DateTime?
  completed     Boolean   @default(false)
  completedDate DateTime?
  completedBy   String?
  notes         String?

  @@index([skuId])
}

// ─── CM Candidate ───────────────────────────────────────────
model CmCandidate {
  id              String    @id @default(cuid())
  skuId           String
  sku             TransitionSku @relation(fields: [skuId], references: [id], onDelete: Cascade)
  cmName          String
  cmContact       String?
  cmEmail         String?
  capability      String?
  outreachDate    DateTime?
  responseReceived Boolean  @default(false)
  responseDate    DateTime?
  quoteReceived   Boolean   @default(false)
  quoteAmount     Float?
  status          String    @default("Under Evaluation") // Under Evaluation, Qualified, Rejected, Selected
  rejectionReason String?
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([skuId])
}

// ─── Attachment (polymorphic) ────────────────────────────────
model Attachment {
  id             String    @id @default(cuid())
  attachableType String    // task, formulation, tech_transfer, tech_transfer_stage, product, brief, component
  attachableId   String    // ID of the parent entity
  module         String?   // npd, active_brief, cm_productivity, etc. (for task-scoped attachments)
  type           String    // email, file, comment
  payload        Json      // type-specific data
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([attachableType, attachableId])
  @@index([createdAt(sort: Desc)])
}

// ─── Tech Transfer Stage ────────────────────────────────────
model TechTransferStage {
  id              String    @id @default(cuid())
  techTransferId  String    // references ModuleItem ID for the tech transfer
  stageOrder      Int
  stageName       String
  status          String    @default("pending") // pending, in_progress, complete, blocked, skipped
  assigneeUserId  String?
  startedAt       DateTime?
  completedAt     DateTime?
  notes           String?
  tasks           TechTransferStageTask[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([techTransferId])
  @@index([stageOrder])
}

// ─── Tech Transfer Stage Task ───────────────────────────────
model TechTransferStageTask {
  id          String    @id @default(cuid())
  stageId     String
  stage       TechTransferStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  taskName    String
  description String?
  status      String    @default("not_started") // not_started, in_progress, complete, blocked
  assigneeUserId String?
  dueDate     DateTime?
  sortOrder   Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([stageId])
}

// ─── Formulation Ingredient ─────────────────────────────────
model FormulationIngredient {
  id              String  @id @default(cuid())
  formulationId   String  // references ModuleItem ID for the formulation
  phase           String  // A, B, C, D, E, Post-Add
  sortOrder       Int     @default(0)
  inciName        String
  tradeName       String?
  supplierId      String?
  function        String? // emollient, surfactant, preservative, fragrance, active, chelator, etc.
  percentage      Float   // % w/w, 4 decimals
  costPerKg       Float?
  isAllergen      Boolean @default(false)
  isPreservative  Boolean @default(false)
  isFragrance     Boolean @default(false)
  notes           String?

  @@index([formulationId])
  @@index([phase])
}

// ─── Formulation Procedure Step ─────────────────────────────
model FormulationProcedureStep {
  id              String  @id @default(cuid())
  formulationId   String  // references ModuleItem ID
  stepNumber      Int
  phaseReference  String? // which phase this step relates to
  instruction     String
  temperatureC    Float?
  mixingSpeedRpm  Int?
  durationMinutes Int?

  @@index([formulationId])
}
